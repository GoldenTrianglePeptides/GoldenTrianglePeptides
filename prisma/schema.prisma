// Prisma schema for Golden Triangle Peptides
// Uses PostgreSQL. Set DATABASE_URL (and DATABASE_URL_UNPOOLED for
// migrations) in the environment — e.g. via the Vercel + Neon integration.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  isAdmin      Boolean  @default(false)
  createdAt    DateTime @default(now())
  orders       Order[]
  passwordResetTokens PasswordResetToken[]
}

/// One-time password reset token. We only store a SHA-256 hash of the token so
/// the raw value (emailed to the user) cannot be reconstructed from the DB.
/// Expires after 30 minutes and is invalidated on first successful use.
model PasswordResetToken {
  id        String    @id @default(cuid())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

model Product {
  id          String           @id @default(cuid())
  slug        String           @unique
  name        String
  description String
  category    String
  cas         String?
  priceCents  Int
  sizeMg      Int
  purity      String
  imageUrl    String
  // Optional structured detail fields rendered on the product page.
  // Empty fields simply don't render — fill them in via /admin per product.
  storage         String? // e.g. "Store lyophilized at -20°C; refrigerate after reconstitution."
  reconstitution  String? // e.g. "Add 1–2 mL bacteriostatic water to the vial."
  researchNotes   String? // free-form research-use-only notes / context
  molecularFormula String? // e.g. C254H377N73O76S2
  molecularWeight  String? // e.g. "5929.7 g/mol"
  sequence         String? // single-letter amino-acid sequence
  featured    Boolean          @default(false)
  inStock     Boolean          @default(true)
  createdAt   DateTime         @default(now())
  variants    ProductVariant[]
  orderItems  OrderItem[]

  @@index([category])
}

/// Size/price options a customer can pick when buying a product.
/// A product with no variants is sold at its base priceCents/sizeMg.
/// A product with one or more variants is sold ONLY through them — the base
/// price/size act as a fallback for legacy single-option products.
model ProductVariant {
  id         String      @id @default(cuid())
  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId  String
  label      String // displayed on the card / picker, e.g. "5 mg" or "20 mg Box"
  sizeMg     Int // numeric size for sorting & display; 0 = non-peptide (e.g. liquid)
  priceCents Int
  inStock    Boolean     @default(true)
  // Units in stock. null = not tracked (treated as unlimited); a number is
  // enforced at checkout and decremented when an order is paid.
  stockQty   Int?
  sortOrder  Int         @default(0)
  createdAt  DateTime    @default(now())
  orderItems OrderItem[]

  @@index([productId, sortOrder])
}

model Order {
  id              String      @id @default(cuid())
  user            User        @relation(fields: [userId], references: [id])
  userId          String
  // Lifecycle: awaiting_payment (crypto invoice open) -> paid -> processing
  // -> shipped -> delivered. Other states: partial, failed, expired, cancelled.
  // Demo orders (no payment processor configured) are created as "paid".
  status          String      @default("awaiting_payment")
  totalCents      Int
  shippingName    String
  shippingEmail   String
  shippingAddress String
  shippingCity    String
  shippingState   String
  shippingZip     String
  // Payment / processor tracking.
  paymentRef      String? // processor invoice/payment id (or DEMO-xxx)
  paymentProvider String? // e.g. "nowpayments"; null for demo orders
  paymentStatus   String? // raw provider status: waiting, confirming, confirmed, finished, partially_paid, failed, expired
  paymentUrl      String? // hosted checkout URL so a pending order can be reopened
  // Fulfillment / shipping.
  trackingNumber  String? // carrier tracking number, set when marked shipped
  trackingCarrier String? // e.g. "USPS", "UPS", "FedEx", "DHL"
  shippedAt       DateTime? // when the order was marked shipped
  // Set when the cron has emailed the customer an abandoned-payment reminder;
  // used to avoid sending more than one reminder per order.
  reminderSentAt  DateTime?
  // Inventory reservation bookkeeping. Stock is reserved (decremented) at
  // checkout; stockReserved records that so we only ever restock orders that
  // actually held a reservation (orders created before this feature have it
  // false). stockReleased makes the restock idempotent across cancel/expire.
  stockReserved   Boolean     @default(false)
  stockReleased   Boolean     @default(false)
  // Last time we pulled this order's status from NOWPayments on view; used to
  // throttle the auto-sync so a polling order page doesn't hammer the API.
  lastSyncedAt    DateTime?
  createdAt       DateTime    @default(now())
  items           OrderItem[]

  @@index([userId])
  @@index([status, createdAt])
  @@index([createdAt])
}

model OrderItem {
  id         String          @id @default(cuid())
  order      Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId    String
  product    Product         @relation(fields: [productId], references: [id])
  productId  String
  variant    ProductVariant? @relation(fields: [variantId], references: [id])
  variantId  String?
  name       String // snapshot at time of order, includes variant label
  priceCents Int
  quantity   Int

  @@index([orderId])
  @@index([productId])
  @@index([variantId])
}
