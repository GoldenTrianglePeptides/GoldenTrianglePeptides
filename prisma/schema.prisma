// Prisma schema for Golden Triangle Peptides
// Using SQLite for zero-config local development.
// To use PostgreSQL in production, change provider to "postgresql"
// and set `url = env("DATABASE_URL")`.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  isAdmin      Boolean  @default(false)
  createdAt    DateTime @default(now())
  orders       Order[]
}

model Product {
  id          String      @id @default(cuid())
  slug        String      @unique
  name        String
  description String
  category    String
  priceCents  Int
  sizeMg      Int
  purity      String
  imageUrl    String
  featured    Boolean     @default(false)
  inStock     Boolean     @default(true)
  createdAt   DateTime    @default(now())
  orderItems  OrderItem[]
}

model Order {
  id              String      @id @default(cuid())
  user            User        @relation(fields: [userId], references: [id])
  userId          String
  status          String      @default("paid") // paid, processing, shipped, delivered, cancelled
  totalCents      Int
  shippingName    String
  shippingEmail   String
  shippingAddress String
  shippingCity    String
  shippingState   String
  shippingZip     String
  paymentRef      String?
  createdAt       DateTime    @default(now())
  items           OrderItem[]
}

model OrderItem {
  id         String  @id @default(cuid())
  order      Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId    String
  product    Product @relation(fields: [productId], references: [id])
  productId  String
  name       String
  priceCents Int
  quantity   Int
}
