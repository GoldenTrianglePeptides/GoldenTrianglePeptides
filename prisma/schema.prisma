// Prisma schema for Golden Triangle Peptides
// Uses PostgreSQL. Set DATABASE_URL (and DATABASE_URL_UNPOOLED for
// migrations) in the environment — e.g. via the Vercel + Neon integration.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  isAdmin      Boolean  @default(false)
  createdAt    DateTime @default(now())
  orders       Order[]
}

model Product {
  id          String           @id @default(cuid())
  slug        String           @unique
  name        String
  description String
  category    String
  cas         String?
  priceCents  Int
  sizeMg      Int
  purity      String
  imageUrl    String
  featured    Boolean          @default(false)
  inStock     Boolean          @default(true)
  createdAt   DateTime         @default(now())
  variants    ProductVariant[]
  orderItems  OrderItem[]
}

/// Size/price options a customer can pick when buying a product.
/// A product with no variants is sold at its base priceCents/sizeMg.
/// A product with one or more variants is sold ONLY through them — the base
/// price/size act as a fallback for legacy single-option products.
model ProductVariant {
  id         String      @id @default(cuid())
  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId  String
  label      String // displayed on the card / picker, e.g. "5 mg" or "20 mg Box"
  sizeMg     Int // numeric size for sorting & display; 0 = non-peptide (e.g. liquid)
  priceCents Int
  inStock    Boolean     @default(true)
  sortOrder  Int         @default(0)
  createdAt  DateTime    @default(now())
  orderItems OrderItem[]

  @@index([productId, sortOrder])
}

model Order {
  id              String      @id @default(cuid())
  user            User        @relation(fields: [userId], references: [id])
  userId          String
  status          String      @default("paid") // paid, processing, shipped, delivered, cancelled
  totalCents      Int
  shippingName    String
  shippingEmail   String
  shippingAddress String
  shippingCity    String
  shippingState   String
  shippingZip     String
  paymentRef      String?
  createdAt       DateTime    @default(now())
  items           OrderItem[]
}

model OrderItem {
  id         String          @id @default(cuid())
  order      Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId    String
  product    Product         @relation(fields: [productId], references: [id])
  productId  String
  variant    ProductVariant? @relation(fields: [variantId], references: [id])
  variantId  String?
  name       String // snapshot at time of order, includes variant label
  priceCents Int
  quantity   Int
}
