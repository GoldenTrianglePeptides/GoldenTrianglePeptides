# --- Database (PostgreSQL) ---
# Set automatically when you add a Postgres database through the
# Vercel dashboard (Storage tab) or the Vercel + Neon integration.
# DATABASE_URL is the pooled connection used at runtime.
# DATABASE_URL_UNPOOLED is the direct connection used for migrations.
DATABASE_URL=
DATABASE_URL_UNPOOLED=

# --- Auth ---
# A long random string used to sign session cookies.
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
AUTH_SECRET=

# --- Initial admin login for the store dashboard (/admin) ---
# Set these BEFORE the first deploy so the live site never uses a default password.
ADMIN_EMAIL=admin@goldentrianglepeptides.com
ADMIN_PASSWORD=
