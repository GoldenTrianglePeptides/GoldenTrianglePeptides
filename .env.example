# --- Database (PostgreSQL) ---
# Set automatically when you add a Postgres database through the
# Vercel dashboard (Storage tab) or the Vercel + Neon integration.
# DATABASE_URL is the pooled connection used at runtime.
# DATABASE_URL_UNPOOLED is the direct connection used for migrations.
DATABASE_URL=
DATABASE_URL_UNPOOLED=

# --- Auth ---
# A long random string used to sign session cookies.
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
AUTH_SECRET=

# --- Initial admin login for the store dashboard (/admin) ---
# Set these BEFORE the first deploy so the live site never uses a default password.
ADMIN_EMAIL=admin@goldentrianglepeptides.com
ADMIN_PASSWORD=

# --- Crypto payments (NOWPayments) ---
# Required for checkout to work. See CRYPTO_SETUP.md for a step-by-step guide.
# If these are missing the checkout will refuse new orders.
# From the NOWPayments dashboard -> Settings -> API keys:
NOWPAYMENTS_API_KEY=
# From Settings -> IPN/Instant Payment Notifications (a secret you generate):
NOWPAYMENTS_IPN_SECRET=

# --- Public site URL ---
# Your live origin, used to build payment success/cancel/callback URLs and
# password reset links. Example: https://goldentrianglepeptide.com  (no trailing slash)
NEXT_PUBLIC_SITE_URL=

# --- Transactional email (Resend) ---
# Required for order receipts, password reset links, and shipping notifications.
# See EMAIL_SETUP.md for the full step-by-step setup.
# From resend.com -> API Keys:
RESEND_API_KEY=
# The verified "from" address. Must match a domain verified in Resend.
# Example: "Golden Triangle Peptides <support@goldentrianglepeptide.com>"
EMAIL_FROM=

# --- Cron jobs ---
# Vercel calls scheduled functions (see vercel.json) with
# "Authorization: Bearer $CRON_SECRET". Generate a long random value with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
# Without this set, the cron endpoint refuses to run.
CRON_SECRET=
